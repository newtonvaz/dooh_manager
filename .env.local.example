# Supabase Configuration
# Get these from your Supabase Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: If using a custom domain or different auth email
# ADMIN_EMAIL=admin@dooh.com

# Electron Player
# URL do CMS para envio de heartbeat e device info
# CMS_URL=https://seu-cms.com
# Código do player (passado via --code ou variável de ambiente)
# PLAYER_CODE=DOOH-001